# ---------------------------------------------------------------------------
# b00ks environment variables
#
# Variables prefixed NEXT_PUBLIC_ or EXPO_PUBLIC_ are bundled into client
# code and are visible to anyone using the app. Never put a secret in them.
# Every other variable below is server-only and must never be referenced
# from apps/web client components or from apps/mobile.
# ---------------------------------------------------------------------------

# --- Application (public) ---------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=b00ks

# --- Supabase (public) -------------------------------------------------------
# Safe to expose: RLS is what actually protects data, not secrecy of these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server only) --------------------------------------------------
# Bypasses Row-Level Security entirely. Server-side only. Never log it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (server only) ---------------------------------------------
# Used only to sign short-lived URLs and verify uploads. Never sent to clients.
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=

# --- Upload limits (server only) ---------------------------------------------
MAX_UPLOAD_SIZE_BYTES=209715200
DEFAULT_USER_STORAGE_QUOTA_BYTES=5368709120

# --- Mobile (public, Expo) ----------------------------------------------------
EXPO_PUBLIC_APP_NAME=b00ks
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# --- Optional observability ----------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=
